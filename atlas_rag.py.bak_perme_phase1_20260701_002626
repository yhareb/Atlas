#!/usr/bin/env python3
"""System-Python safe Atlas RAG query bridge.

This module intentionally does not import chromadb at top level. It shells out to
Atlas' ingestion virtualenv, where ChromaDB and embedding dependencies live.
"""
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any

VENV_PYTHON = Path("/Users/yasser/scripts/.atlas_ingest_venv/bin/python")
VECTORDB_PATH = Path("/Users/yasser/atlas_vectordb/")
COLLECTION = "atlas_knowledge"


def _warn(message: str) -> None:
    print(f"[atlas_rag] warning: {message}", file=sys.stderr, flush=True)


def query_knowledge_base(query: str, n_results: int = 5) -> list[dict]:
    """Query Atlas' local Chroma knowledge base.

    Returns: [{"text": str, "source": str, "distance": float}, ...]
    Never raises for missing venv/vector DB/empty collection/query failures.
    """
    query = str(query or "").strip()
    if not query:
        return []
    try:
        n = max(1, int(n_results or 5))
    except Exception:
        n = 5
    if not VENV_PYTHON.exists():
        _warn(f"venv python missing: {VENV_PYTHON}")
        return []
    if not VECTORDB_PATH.exists():
        _warn(f"vector DB missing: {VECTORDB_PATH}")
        return []

    code = """
import chromadb, json, sys
try:
    client = chromadb.PersistentClient(path='/Users/yasser/atlas_vectordb/')
    col = client.get_collection('atlas_knowledge')
    if col.count() <= 0:
        print(json.dumps({'empty': True}))
        raise SystemExit(0)
    results = col.query(query_texts=[sys.argv[1]], n_results=int(sys.argv[2]))
    print(json.dumps(results))
except Exception as exc:
    print(json.dumps({'error': f'{type(exc).__name__}: {exc}'}))
"""
    try:
        proc = subprocess.run(
            [str(VENV_PYTHON), "-c", code, query, str(n)],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=20,
            check=False,
        )
    except Exception as exc:
        _warn(f"query subprocess failed: {type(exc).__name__}: {exc}")
        return []
    if proc.returncode != 0:
        _warn(f"query subprocess exit={proc.returncode}: {proc.stderr.strip()[:240]}")
        return []
    raw = (proc.stdout or "").strip().splitlines()
    if not raw:
        if proc.stderr.strip():
            _warn(proc.stderr.strip()[:240])
        return []
    try:
        payload = json.loads(raw[-1])
    except Exception as exc:
        _warn(f"invalid query JSON: {exc}; stdout={proc.stdout[-240:]!r}")
        return []
    if payload.get("empty") or payload.get("error"):
        if payload.get("error"):
            _warn(payload["error"])
        return []
    docs = (payload.get("documents") or [[]])[0] if isinstance(payload.get("documents"), list) else []
    metas = (payload.get("metadatas") or [[]])[0] if isinstance(payload.get("metadatas"), list) else []
    distances = (payload.get("distances") or [[]])[0] if isinstance(payload.get("distances"), list) else []
    out: list[dict[str, Any]] = []
    for i, text in enumerate(docs or []):
        meta = metas[i] if i < len(metas) and isinstance(metas[i], dict) else {}
        dist = distances[i] if i < len(distances) else None
        try:
            dist_val = float(dist) if dist is not None else 0.0
        except Exception:
            dist_val = 0.0
        out.append({"text": str(text or ""), "source": str(meta.get("source") or ""), "distance": dist_val})
    return out


__all__ = ["query_knowledge_base"]
