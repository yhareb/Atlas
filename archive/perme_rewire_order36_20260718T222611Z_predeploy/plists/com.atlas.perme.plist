    <!-- Friday trading 16:30 ET post-market = Saturday 00:30 +04 -->
    <dict><key>Weekday</key><integer>7</integer><key>Hour</key><integer>0</integer><key>Minute</key><integer>30</integer></dict>
                  </array>
</dict>
