<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.atlas.perme</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/yasser/.hermes/hermes-agent/venv/bin/python</string>
    <string>/Users/yasser/scripts/atlas_perme.py</string>
    <string>--routine</string>
    <string>auto</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HERMES_HOME</key>
    <string>/Users/yasser/.hermes/profiles/perme</string>
    <key>PATH</key>
    <string>/Users/yasser/.hermes/hermes-agent/venv/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
